    parm {
        name    "clip"
        label   "Clip"
        type    string
        default { "default" }
        parmtag { "script_callback_language" "python" }
    }
    parm {
        name    "sepparm"
        label   "Separator"
        type    separator
        default { "" }
    }
    parm {
        name    "frame_range"
        label   "Files Frame Start/End"
        type    integer
        size    2
        default { "1" "24" }
        range   { 0 10 }
        parmtag { "script_callback_language" "python" }
    }
    parm {
        name    "scene_range"
        label   "Scene Frame Start/End"
        type    integer
        size    2
        default { "1" "24" }
        range   { 0 10 }
        parmtag { "script_callback_language" "python" }
    }
    parm {
