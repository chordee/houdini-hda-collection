Content-Disposition: attachment; filename="hdaroot/usd_rop1.chn"
Content-Type: text/plain

{
    channel f1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 55.899999999999999
      segment { length = 0 value = 1 1 expr = $FSTART }
    }
    channel f2 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      start = 55.899999999999999
      segment { length = 0 value = 240 240 expr = $FEND }
    }
    channel frame_range1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 55.899999999999999
      segment { length = 0 value = 1 1 expr = ch(\"../frame_range1\") }
    }
    channel frame_range2 {
      lefttype = extend
      righttype = extend
      default = 24
      flags = 0
      start = 55.899999999999999
      segment { length = 0 value = 24 24 expr = ch(\"../frame_range2\") }
    }
    channel scene_range1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 55.899999999999999
      segment { length = 0 value = 1 1 expr = ch(\"../scene_range1\") }
    }
    channel scene_range2 {
      lefttype = extend
      righttype = extend
      default = 24
      flags = 0
      start = 55.899999999999999
      segment { length = 0 value = 24 24 expr = ch(\"../scene_range2\") }
    }
    channel loop {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 55.899999999999999
      segment { length = 0 expr = ch(\"../loop\") }
    }
    channel lopoutput {
      lefttype = extend
      righttype = extend
      defaultString = \"D:/tmp/tmp.usda\"
      flags = 0
      start = 55.899999999999999
      segment { length = 0 expr = chs(\"../lopoutput\") }
    }
    channel execute {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 55.899999999999999
      segment { length = 0 expr = ch(\"../execute\") }
    }
    channel enableoutputprocessor_simplerelativepaths {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../enableoutputprocessor_simplerelativepaths\") }
    }
    channel simplerelativepaths_spacer {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      segment { length = 0 expr = chs(\"../simplerelativepaths_spacer\") }
    }
  }

