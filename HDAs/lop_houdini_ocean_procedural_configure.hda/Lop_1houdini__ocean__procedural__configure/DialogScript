                }
                parm {
                    name    "streaksharpness"
                    label   "Sharpness"
                    type    float
                    default { "0.8" }
                    range   { 0 1 }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "streakfreq"
                    label   "Frequency"
                    type    vector
                    size    3
                    default { "1.5" "1.5" "1.5" }
                    range   { 0 10 }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "streakoffset"
                    label   "Offset"
                    type    vector
                    size    3
                    default { "0" "0" "0" }
                    range   { 0 10 }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            group {
                name    "folder5_1"
                label   "Bubbles"

                parm {
                    name    "bubblefreq"
                    label   "Frequency"
                    type    vector
                    size    3
                    default { "35" "35" "35" }
                    range   { 0 10 }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "bubbleoffset"
                    label   "Offset"
                    type    vector
                    size    3
                    default { "0" "0" "0" }
                    range   { 0 10 }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback_language" "python" }
                }
            }

        }

        group {
            name    "folder4_1_1_1"
            label   "Displacement"
            disablewhentab "{ cusp == 0 enablefoam == 0 }"

            parm {
                name    "cuspdisplace"
                label   "Cusp Displacement"
                type    float
                default { "0.1" }
                disablewhen "{ cusp == 0 }"
                range   { 0 1 }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "foamdisplace"
                label   "Foam Displacement"
                type    float
                default { "0.1" }
                disablewhen "{ enablefoam == 0 }"
                range   { 0 1 }
                parmtag { "script_callback_language" "python" }
            }
        }

    }

}
