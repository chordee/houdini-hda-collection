            group {
                name    "folder5"
                label   "Streaks"

                parm {
                    name    "streakdir"
                    label   "Direction"
                    type    float
                    default { "0" }
                    range   { 0 10 }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "streakbias"
                    label   "Bias"
                    type    float
                    default { "0" }
