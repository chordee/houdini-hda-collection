Content-Disposition: attachment; filename="hdaroot/define_and_setup_ocean_procedural_surface.spareparmdef"
Content-Type: text/plain

    parm {
        name    "procprim"
        label   "Procedural prim"
        type    string
        default { "`lopinputprims('.', 0)`" }
        help    "None"
        hidewhen "{ createprims == on }"
        menutoggle {
            [ "import loputils" ]
            [ "return loputils.createPrimPatternMenu(kwargs['node'], 0)" ]
            language python
        }
        parmtag { "script_action" "import loputils\nloputils.selectPrimsInParm(kwargs, True)" }
        parmtag { "script_action_help" "Select primitives in the Scene Viewer or Scene Graph Tree pane. Ctrl-click to select using the primitive picker dialog." }
        parmtag { "script_action_icon" "BUTTONS_reselect" }
        parmtag { "sidefx::usdpathtype" "primlist" }
        parmtag { "spare_category" "USD Prims" }
    }
    parm {
        name    "graph"
        label   "Graph"
        type    file
        default { "$HIP/graphs/subdivide.bgeo.sc" }
        parmtag { "script_callback_language" "python" }
    }
    parm {
        name    "initparms"
        label   "Initialize Parmeters"
        type    button
        default { "0" }
        parmtag { "script_callback_language" "python" }
    }
    groupcollapsible {
        name    "tabs_1"
        label   "Output"
        invisibletab

        parm {
            name    "dstprim"
            label   "Rendered Hair Curve"
            type    string
            default { "." }
            help    "None"
            hidewhen "{ createprims == on }"
            menutoggle {
                [ "import loputils" ]
                [ "return loputils.createPrimPatternMenu(kwargs['node'], 0)" ]
                language python
            }
            parmtag { "script_action" "import loputils\nloputils.selectPrimsInParm(kwargs, True)" }
            parmtag { "script_action_help" "Select primitives in the Scene Viewer or Scene Graph Tree pane. Ctrl-click to select using the primitive picker dialog." }
            parmtag { "script_action_icon" "BUTTONS_reselect" }
            parmtag { "sidefx::usdpathtype" "primlist" }
            parmtag { "spare_category" "USD Prims" }
        }
    }

    groupcollapsible {
        name    "tabs_2"
        label   "Parameters"

        parm {
            name    "grid"
            label   "Grid"
            type    string
            default { "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_group"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "group"
            label   "Group"
            type    string
            default { "" }
            disablewhen "{ override_group == 0 }"
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "animated"
            label   "Animated Procedural"
            type    toggle
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_dicing"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "dicing"
            label   "Dicing"
            type    float
            default { "2" }
            disablewhen "{ override_dicing == 0 }"
            range   { 0 10 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_spectra"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "spectra"
            label   "Spectra File"
            type    geometry
            default { "0" }
            disablewhen "{ override_spectra == 0 }"
            range   { 0 10 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_mask"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "mask"
            label   "Mask File"
            type    geometry
            default { "" }
            disablewhen "{ override_mask == 0 }"
            range   { 0 10 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_foamfile"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "foamfile"
            label   "Foam File"
            type    geometry
            default { "0" }
            disablewhen "{ override_foamfile == 0 }"
            range   { 0 10 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_previewquality"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "previewquality"
            label   "Preview Quality"
            type    float
            default { "0.25" }
            disablewhen "{ override_previewquality == 0 }"
            range   { 0 1 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_downsample"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "downsample"
            label   "Downsample"
            type    integer
            default { "2" }
            disablewhen "{ override_downsample == 0 }"
            range   { 0 10 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "override_verbose"
            label   "Label"
            type    toggle
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "verbose"
            label   "Verbose"
            type    integer
            default { "2" }
            disablewhen "{ override_verbose == 0 }"
            range   { 0 10 }
            parmtag { "script_callback_language" "python" }
        }
        parm {
