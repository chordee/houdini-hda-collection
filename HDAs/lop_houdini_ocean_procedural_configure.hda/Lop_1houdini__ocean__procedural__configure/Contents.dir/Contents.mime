--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/ocean_materials/mtlxoceaninterior.spareparmdef"
Content-Type: text/plain

    groupcollapsible {
        name    "folder1"
        label   "MaterialX Subnet"
        invisibletab

        parm {
            name    "tabmenumask"
            label   "Tab Menu Mask"
            type    string
            default { "MaterialX parameter collect subnet null subnetconnector" }
            parmtag { "spare_category" "Tab Menu" }
        }
    }

    parm {
        name    "volumecolor"
        label   "Volume Color"
        type    color
        size    3
        default { "0.45" "0.65" "0.54" }
        range   { 0 1 }
        parmtag { "parmvop" "1" }
    }
    parm {
        name    "volumedensity"
        label   "Volume Density"
        type    float
        default { "0.3" }
        range   { 0 1 }
        parmtag { "parmvop" "1" }
    }
    parm {
        name    "phase"
        label   "Scattering Phase"
        type    float
        default { "0.5" }
        range   { -1 1 }
        parmtag { "parmvop" "1" }
    }

