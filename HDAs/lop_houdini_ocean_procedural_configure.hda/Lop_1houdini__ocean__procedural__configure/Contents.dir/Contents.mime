      flags = 0
      segment { length = 0 expr = chs(\"../dicing_and_bumpmap_settings/xn__primvarskarmaobjectuvunwrap_highres_obj_control_oicfg\") }
    }
    channel xn__primvarskarmaobjectuvunwrap_cage_obj_rzbfg {
