--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/define_and_setup_ocean_procedural_surface.parm"
Content-Type: text/plain

{
version 0.8
python	[ 0	locks=0 ]	(	"from husd import UsdHoudini
from pxr import Sdf, UsdGeom, Gf

node = hou.pwd()
name = 'define_and_setup_ocean_procedural'
parent = node.parent()

# Resolved Guide/Skin Input Paths before editableStage()
# to avoid Read Lock Failed issues.
input_parms = ['grid']
input_prim_paths = {}

sel = hou.LopSelectionRule()

for iparm in input_parms:
    parm = node.parm(iparm)
    sel.setPathPattern(parm.eval())
    input_prim_paths[iparm] = sel.expandedPaths(node.inputs()[0])

stage = node.editableStage()

prim = stage.GetPrimAtPath(node.evalParm('procprim'))
pv_api = UsdGeom.PrimvarsAPI(prim)

oceanprocedural_parms = ['group',
                        'dicing',
                        'spectra',
                        'mask',
                        'foamfile',
                        'previewquality',
                        'downsample',
                        'verbose',
                        'time',
                        'frame',
                        'aablur',
                        'cusp',
                        'cusprange',
                        'cuspgamma',
                        'cuspint',
                        'pointvel',
                        'winsize',
                        # foam pattern parameters
                        'foamradscale',
                        'foamalpha',
                        'foamfilterwidth',
                        'foamrange',
                        'foamgamma',
                        'foamint',
                        'streaksharpness',
                        'streakfreq',
                        'streakoffset',
                        'streakdir',
                        'streakbias',
                        'bubblefreq',
                        'bubbleoffset',
                        'cuspdisplace',
                        'foamdisplace']

args = { 'graph': node.evalParm('graph'),
         'inputs': [], 'overrides': {} }

# INPUTS
for i, iname in enumerate(input_parms):
     rel_name = '{}:input_{}'.format(iname, i)
     rel = prim.CreateRelationship(rel_name)
     for path in input_prim_paths[iname]:
         rel.AddTarget(path)
     args['inputs'].append(rel_name)

# OUTPUT
#pv_name = '{}:output'.format(name)
#pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.String)
#pv.SetIdTarget(node.evalParm('dstprim'))
#args['output'] = pv_name
    
# OVERRIDES
for oceanproc_parm in oceanprocedural_parms:
    parm = node.parm(oceanproc_parm)
    if (node.parm(\"override_\"+oceanproc_parm) and node.parm(\"override_\"+oceanproc_parm).eval()):
        p_name = oceanproc_parm
        pv_name = '{}:{}'.format(name, p_name)
        parm = node.parm(p_name)
        if parm:
            val = parm.eval()
            if type(val) == str:
                # Create any file parameters as asset paths.
                if parm.parmTemplate().interfaceType() == 'file_geometry':
                    pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Asset)
                else:
                    pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.String)
            elif type(val) == float:
                pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Float)
            elif type(val) == int:
                pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Int)
            else:
                continue
        else:
            parm = node.parmTuple(p_name)
            parm_t = parm.parmTemplate()
            n = parm_t.numComponents()        
            datatype = parm_t.dataType()
            val = parm.eval()
            if n == 3 and datatype == hou.parmData.Float:
                pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Vector3f)
            elif n == 4 and datatype == hou.parmData.Float:
                pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Vector4f)
            elif n == 2 and datatype == hou.parmData.Float:
                pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Float2)
            elif n == 2 and datatype == hou.parmData.Int:
                pv = pv_api.CreatePrimvar(pv_name, Sdf.ValueTypeNames.Int2)
                val = Gf.Vec2i(val)
            else:
                continue

        if parm.isTimeDependent():
            pv.Set(val, hou.frame())
        else:
            pv.Set(val)
        args['overrides'][p_name] = pv_name

hp_api = UsdHoudini.HoudiniProceduralAPI.Apply(prim, node.parent().name())
#hp_api.GetHoudiniProceduralPathAttr().Set('$HIP/dicegraph.py')
hp_api.GetHoudiniProceduralPathAttr().Set('invokegraph.py')
hp_api.GetHoudiniProceduralArgsAttr().Set(str(args))
hp_api.GetHoudiniAnimatedAttr().Set(node.evalParm('animated'))"	)
