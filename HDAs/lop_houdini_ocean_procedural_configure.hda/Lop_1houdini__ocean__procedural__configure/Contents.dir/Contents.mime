--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/ocean_materials/mtlxoceansurface.spareparmdef"
Content-Type: text/plain

    groupcollapsible {
        name    "folder1"
        label   "MaterialX Subnet"
        invisibletab

        parm {
            name    "tabmenumask"
            label   "Tab Menu Mask"
            type    string
            default { "MaterialX parameter collect subnet null subnetconnector" }
            parmtag { "spare_category" "Tab Menu" }
        }
    }

    group {
        name    "folder2"
        label   "Waves"

        parm {
            name    "waveheightmin"
            label   "Height Min"
            type    float
            default { "-3" }
            range   { 0 10 }
            parmtag { "parmvop" "1" }
        }
        parm {
            name    "waveheightmax"
            label   "Height Max"
            type    float
            default { "3" }
            range   { 0 10 }
            parmtag { "parmvop" "1" }
        }
        parm {
            name    "waveheightgamma"
            label   "Height Gamma"
            type    float
            default { "1" }
            range   { 0 10 }
            parmtag { "parmvop" "1" }
        }
        group {
            name    "folder9"
            label   "Diffuse"

            parm {
                name    "wavediffint"
                label   "Diffuse Intensity"
                type    float
                default { "0.05" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "wavedifftex"
                label   "Diffuse Color Texture"
                type    image
                default { "$HH/pic/oceanramp.exr" }
                parmtag { "script_callback_language" "python" }
            }
        }

        group {
            name    "folder9_1"
            label   "Specular"

            parm {
                name    "wavespecint"
                label   "Specular Intensity"
                type    float
                default { "0.85" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "wavespecrough"
                label   "Specular Roughness"
                type    float
                default { "0.1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "wavespeccolor"
                label   "Specular Color"
                type    color
                size    3
                default { "1" "1" "1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
        }

        group {
            name    "folder9_2"
            label   "Transmission"
            tabbreak
            disablewhentab "{ enabletransmission == 0 }"

            parm {
                name    "wavetransmissionint"
                label   "Transmission Intensity"
                type    float
                default { "0.5" }
                disablewhen "{ enabletransmission == 0 }"
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "wavetransmissioncolor"
                label   "Transmission Color"
                type    color
                size    3
                default { "0.6192" "0.70992" "0.72" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
        }

    }

    group {
        name    "folder2_1"
        label   "Foam"

        group {
            name    "folder5"
            label   "Diffuse"

            parm {
                name    "whitecapcolor"
                label   "Whitecap Color"
                type    color
                size    3
                default { "1" "1" "1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "foamcolor"
                label   "Foam Color"
                type    color
                size    3
                default { "1" "1" "1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
        }

        group {
            name    "folder5_1"
            label   "Specular"

            parm {
                name    "foamspecint"
                label   "Specular Intensity"
                type    float
                default { "1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "foamspecrough"
                label   "Specular Roughness"
                type    float
                default { "0.2" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "foamspeccolor"
                label   "Specular Color"
                type    color
                size    3
                default { "1" "1" "1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
        }

        group {
            name    "folder5_2"
            label   "Transmission"
            tabbreak
            disablewhentab "{ enabletransmission == 0 }"

            parm {
                name    "foamtransmissionint"
                label   "Transmission Intensity"
                type    float
                default { "0.25" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "foamtransmissioncolor"
                label   "Transmission Color"
                type    color
                size    3
                default { "0.435715" "0.492" "0.362112" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
        }

        group {
            name    "folder3_2"
            label   "Bump Mapping"
            disablewhentab "{ enablebump == 0 }"

            parm {
                name    "whitecapbump"
                label   "Whitecap Bump"
                type    float
                default { "0.1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
            parm {
                name    "foambump"
                label   "Foam Bump"
                type    float
                default { "0.1" }
                range   { 0 1 }
                parmtag { "parmvop" "1" }
            }
        }

    }

    group {
        name    "folder2_2"
        label   "Settings"

        parm {
            name    "specular_IOR"
            label   "Index of Refraction"
            type    float
            default { "1.33" }
            range   { 0 3 }
            parmtag { "ogl_ior" "1" }
            parmtag { "parmvop" "1" }
        }
        parm {
            name    "enabletransmission"
            label   "Enable Transmission"
            type    toggle
            default { "off" }
            parmtag { "parmvop" "1" }
        }
        parm {
            name    "enablebump"
            label   "Enable Bump Mapping"
            type    toggle
            default { "off" }
            parmtag { "parmvop" "1" }
        }
    }


--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/ocean_materials/mtlxoceansurface.chn"
Content-Type: text/plain

{
    channel enabletransmission {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = ch(\"../../enableinterior\") }
    }
  }

