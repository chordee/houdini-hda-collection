    }
    channel xn__primvarskarmaobjectuvunwrap_highres_obj_n4bfg {
      lefttype = extend
      righttype = extend
      default = -1
      flags = 0
      segment { length = 0 value = -1 -1 expr = ch(\"../dicing_and_bumpmap_settings/xn__primvarskarmaobjectuvunwrap_highres_obj_n4bfg\") }
    }
    channel xn__primvarskarmaobjectuvunwrap_highres_obj_control_oicfg {
      lefttype = extend
