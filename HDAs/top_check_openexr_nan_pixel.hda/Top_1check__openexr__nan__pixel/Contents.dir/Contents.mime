err_num = work_item.attribValue('err')
num = work_item.attribValue('partitionsize')

log_path = hou.pwd().node('..').parm('log_file').eval()

with open(log_path, 'a') as f:
    f.writelines(['\\n\\t', f'...Found {err_num} Errors in {num} Files','\\n'])

