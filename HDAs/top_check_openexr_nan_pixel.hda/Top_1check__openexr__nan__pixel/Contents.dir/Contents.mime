batchsize	[ 0	locks=0 ]	(	1	)
prescript	[ 0	locks=0 ]	(	"# Script code that runs once before a batch begins.
#
# The following variables are available:
# work_item    - the work item currently running 
# graph        - the graph attributes for the current work item
#
# In addition to the above, in-process scripts can also access:
# self         - the current PDG node
# parent_item  - the parent work item, if it exists
"	)
expansion	[ 0	locks=0 ]	(	0	)
expandscript	[ 0	locks=0 ]	(	"off"	)
expandstrings	[ 0	locks=0 ]	(	"off"	)
script	[ 0	locks=0 ]	(	"# Script code that runs for each task in the node.
#
# The following variables are available:
# work_item    - the work item currently running 
# graph        - the graph attributes for the current work item
#
# In addition to the above, in-process scripts can also access:
# self         - the current PDG node
# parent_item  - the parent work item, if it exists

import OpenImageIO as oiio
import numpy as np
import hou

def image_proc(file):
    res = None
    try:
        inp = oiio.ImageInput.open(file)
        data = inp.read_image()
        max_val = np.max(data)
        if np.isnan(max_val):
            print(file)
            res = file
            work_item.setIntAttrib('err', 1)
        inp.close()
        return res
    except Exception as e:
        print(e)
        inp.close()
        return res

files = work_item.inputFiles
filepath = files[0].path

log_path = hou.pwd().node('..').parm('log_file').eval()

result = image_proc(filepath)

if result != None:
    with open(log_path, 'a') as f:
        f.writelines([result,'\\n'])

"	)
